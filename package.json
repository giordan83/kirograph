    "test:patterns:mcp": "bash test/patterns/mcp.sh",
    "test:security:mcp": "bash test/security/mcp.sh",
    "test:turboquant:mcp": "bash test/turboquant/mcp.sh",
    "test:turbovec:mcp": "bash test/turbovec/mcp.sh",
    "test:watchmen:mcp": "bash test/watchmen/mcp.sh --skip-llm",
    "test:wiki:mcp": "bash test/wiki/mcp.sh --skip-llm",
    "test:integration:mcp": "bash test/agent/mcp.sh --no-build && bash test/architecture/mcp.sh --no-build && bash test/branch/mcp.sh --no-build && bash test/data/mcp.sh --no-build && bash test/edit/mcp.sh --no-build && bash test/git/mcp.sh --no-build && bash test/graph/mcp.sh --no-build && bash test/health/mcp.sh --no-build && bash test/insights/mcp.sh --no-build && bash test/mem/mcp.sh --no-build && bash test/patterns/mcp.sh --no-build && bash test/security/mcp.sh --no-build && bash test/turboquant/mcp.sh --no-build && bash test/turbovec/mcp.sh --no-build --skip-native && bash test/watchmen/mcp.sh --no-build --skip-llm && bash test/wiki/mcp.sh --no-build --skip-llm",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "release": "./scripts/release.sh",
    "docs": "npx serve docs"
  },
