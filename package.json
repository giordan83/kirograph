    "test:agent:mcp": "bash test/agent/mcp.sh",
    "test:architecture:mcp": "bash test/architecture/mcp.sh",
    "test:branch:mcp": "bash test/branch/mcp.sh",
    "test:data:mcp": "bash test/data/mcp.sh",
    "test:edit:mcp": "bash test/edit/mcp.sh",
    "test:git:mcp": "bash test/git/mcp.sh",
    "test:graph:mcp": "bash test/graph/mcp.sh",
    "test:health:mcp": "bash test/health/mcp.sh",
    "test:insights:mcp": "bash test/insights/mcp.sh",
